{
  "name": "project",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://novabridgeconsultancyservices.in",
  "scripts": {
    "dev": "vite",
    "dev:client": "vite",
    "dev:server": "bun --watch run server.tsx",
    "vercel:dev": "vite preview --host --port 3000",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist",

    "start": "bun run server.tsx",
    "generate": "bun ./node_modules/@shogo-ai/sdk/bin/cli.mjs generate",
    "db:generate": "bun x --bun prisma generate",
    "db:migrate:dev": "bun x --bun prisma migrate dev",
    "db:migrate:deploy": "bun x --bun prisma migrate deploy",
    "db:push": "bun x --bun prisma db push",
    "db:reset": "bun x --bun prisma db push --force-reset --accept-data-loss",
    "db:studio": "bun x --bun prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-libsql": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@shogo-ai/sdk": "^1.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.0.0",
    "lucide-react": "^0.563.0",
    "mobx": "^6.13.0",
    "mobx-react-lite": "^4.0.0",
    "ms": "^2.1.3",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.18.0",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@prisma/internals": "^7.3.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^8.2.0",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.6",
    "prisma": "^7.3.0",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.0.0"
  }
}
